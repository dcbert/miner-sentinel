version: "3.7"

services:
  app_proxy:
    environment:
      APP_HOST: miner-sentinel_frontend_1
      APP_PORT: 80

  db:
    image: postgres:17.7@sha256:bac8128cd62a35471a1e97966861aa2ac88c8d2f408767a425ae70695a607c99
    user: "1000:1000"
    restart: on-failure
    stop_grace_period: 1m
    volumes:
      - ${APP_DATA_DIR}/data/db:/var/lib/postgresql/data
    environment:
      POSTGRES_USER: minersentinel
      POSTGRES_PASSWORD: minersentinel
      POSTGRES_DB: minersentinel
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U minersentinel"]
      interval: 10s
      timeout: 5s
      retries: 5

  backend:
    image: dcbert/minersentinel-backend:latest@sha256:24d1ab8df5bdc3326ad81c4343e472e34a113d4c31330342f588321acfe54bff
    restart: on-failure
    stop_grace_period: 1m
    depends_on:
      - db
    environment:
      # Database configuration
      DB_HOST: miner-sentinel_postgres_1
      DB_PORT: 5432
      POSTGRES_DB: minersentinel
      POSTGRES_USER: minersentinel
      POSTGRES_PASSWORD: minersentinel
      # Django settings
      DJANGO_SECRET_KEY: ${APP_SEED}
      DJANGO_DEBUG: "False"
      ALLOWED_HOSTS: "*"
      CORS_ALLOWED_ORIGINS: "http://${DEVICE_DOMAIN_NAME}:3080,http://*.ts.net:3080"
      CSRF_TRUSTED_ORIGINS: "http://${DEVICE_DOMAIN_NAME}:3080,http://*.ts.net:3080"
      DJANGO_SUPERUSER_USERNAME: admin
      DJANGO_SUPERUSER_PASSWORD: $APP_PASSWORD
      DJANGO_SUPERUSER_EMAIL: "admin@umbrel.local"
      # API URL for frontend
      API_BASE_URL: "http://${DEVICE_DOMAIN_NAME}:3080"
    command: >
      sh -c "
        python manage.py migrate &&
        python manage.py collectstatic --noinput &&
        (python manage.py createsuperuser --no-input ||
        echo 'Superuser already exists or created — winning!') &&
        gunicorn minersentinel.wsgi:application --bind 0.0.0.0:8000 --workers 2 --timeout 120
      "

  frontend:
    image: dcbert/minersentinel-frontend:latest@sha256:aec17969a4b99362554f3265e58442e216c66e963e87721b55182e242a2d0c16
    restart: on-failure
    stop_grace_period: 1m
    depends_on:
      - backend
    environment:
      VITE_API_URL: "http://${DEVICE_DOMAIN_NAME}:3080"

  data-service:
    image: dcbert/minersentinel-data-service:latest@sha256:b1a93c2bb54c6cb2092317db52fa852b59d3bcc34c226af426e0dff9aa01cd9d
    restart: on-failure
    stop_grace_period: 1m
    depends_on:
      - db
      - backend
    environment:
      # Database configuration
      POSTGRES_HOST: miner-sentinel_postgres_1
      POSTGRES_PORT: 5432
      POSTGRES_DB: minersentinel
      POSTGRES_USER: minersentinel
      POSTGRES_PASSWORD: minersentinel
      # Backend API
      BACKEND_URL: "http://miner-sentinel_backend_1:8000"
      # Polling intervals (in seconds)
      BITAXE_POLL_INTERVAL: 60
      AVALON_POLL_INTERVAL: 60
      POOL_POLL_INTERVAL: 300
      # Telegram notifications (optional - configure via Django admin / Settings page)
      TELEGRAM_BOT_TOKEN: ""
      TELEGRAM_CHAT_ID: ""
      # Discord notifications (optional)
      DISCORD_WEBHOOK_URL: ""
